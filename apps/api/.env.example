# --- App ---
ENVIRONMENT=development
API_V1_PREFIX=/api/v1
CORS_ORIGINS=["http://localhost:3000"]

# --- Database ---
# If 5432 is taken locally, start compose with KELP_DB_PORT=5544 and use that port here.
DB_NAME=kelp_nexus
DB_HOST=localhost
DB_USER=postgres
DB_PASSWORD=change-me
DB_PORT=5432
DB_ENABLE_SSL=false
# --- Auth ---
JWT_SECRET=change-me-in-prod
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440
DEV_LOGIN=true

# --- Storage backend: "azure" (Azure Blob) or "sharepoint" (Microsoft Graph) ---
STORAGE_BACKEND=azure

# --- Azure Blob (used when STORAGE_BACKEND=azure) ---
# Leave account name/key empty to use the local Azurite connection string.
# For real Azure, set the account name + key (keep real values in .env, never here).
AZURE_BLOB_CONTAINER=reports
AZURE_ACCOUNT=
AZURE_ACCOUNT_KEY=
AZURE_CONTAINER_PATH=

# --- SharePoint (used when STORAGE_BACKEND=sharepoint; delegated Graph token) ---
# SHAREPOINT_SITE: site name (resolved via Graph search) or "host:/sites/Name".
# SHAREPOINT_LIBRARY: document library display name; blank = site's default library.
# Requires the delegated Graph scope below + one-time admin consent on the Entra app.
SHAREPOINT_SITE=fullvaluetech.sharepoint.com:/sites/Kelp-Nexus
SHAREPOINT_LIBRARY=
SHAREPOINT_ROOT_FOLDER=reports
GRAPH_SCOPES=["Sites.ReadWrite.All"]

# --- AI (Claude). Leave ENABLE_AI=false to run without AI ---
ENABLE_AI=false
ANTHROPIC_API_KEY=
AI_MODEL=claude-opus-4-8
EMBEDDING_DIM=1536

# ── Microsoft Entra ID / MSAL ─────────────────────────────────────────────────
# client_id / tenant_id are identifiers, not secrets. The CLIENT SECRET is a live
# credential — keep it only in your local .env, never commit it here.
# Register MSAL_REDIRECT_URI (…/api/v1/auth/callback) on the Entra app + grant
# admin consent for delegated Sites.ReadWrite.All before SharePoint uploads work.
MSAL_CLIENT_ID=197041b6-7372-4afb-9cd0-ae1cb04d860c
MSAL_TENANT_ID=311834f4-5f64-42d1-956a-590577219596
MSAL_CLIENT_SECRET=
MSAL_REDIRECT_URI=http://localhost:3000/api/v1/auth/callback
